{
  "name": "tscope",
  "version": "0.5.1",
  "description": "CLI tool to inspect local GitHub Copilot session token usage and estimated AI credits",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "tscope": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "npx jest",
    "lint": "eslint src --ext .ts",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "keywords": [
    "copilot",
    "tokens",
    "usage",
    "cli",
    "github"
  ],
  "author": "robpitcher",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/robpitcher/tscope"
  },
  "bugs": {
    "url": "https://github.com/robpitcher/tscope/issues"
  },
  "homepage": "https://github.com/robpitcher/tscope#readme",
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    }
  }
}
